# Installed as /etc/praeco/.env-telegram (mode 640, root:praeco)
# Copy this file there and fill in real values. install.sh does this
# automatically on first install and never overwrites an existing file.

# Telegram bot token and destination chat ID, used by `praeco`.
PRAECO_TOKEN=PRAECO-TOKEN
PRAECO_CHAT_ID=PRAECO-CHAT-ID

# From address used by `praecomail`. Optional: defaults to
# praeco@<hostname> if unset.
PRAECOMAIL_FROM=alerts@example.com
