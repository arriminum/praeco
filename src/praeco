#!/bin/sh
#
# praeco - send a message to Telegram via a bot.
#
# Usage: praeco [--source NAME] "message" [silent]
#        praeco --version
#
#   --source NAME  Optional label identifying the caller (app, site, script).
#                  Prefixed to the message as bold "NAME: " text.
#   --version      Print the installed version and exit.
#   message        Text to send (required). Telegram Markdown is supported.
#   silent         Optional literal "silent" to suppress Telegram's API
#                  response from being printed to stdout on success.
#
# A "[praeco] hash: <16 hex chars>" line is always printed to stderr before
# sending, matching the hash= field logged for this attempt, so it can be
# used to correlate a run with its log line during debugging.
#
# Configuration is read from $PRAECO_ENV_FILE (default:
# /etc/praeco/.env-telegram), which must define PRAECO_TOKEN and
# PRAECO_CHAT_ID. See docs/usage.md for details.

set -eu

ENV_FILE="${PRAECO_ENV_FILE:-/etc/praeco/.env-telegram}"
LOG_FILE="${PRAECO_LOG_FILE:-/var/log/praeco/praeco.log}"
VERSION_FILE="${PRAECO_VERSION_FILE:-/usr/local/lib/praeco/VERSION}"

log() {
    printf '%s [praeco] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$1" >>"$LOG_FILE" 2>/dev/null || true
}

SOURCE=""
while [ "$#" -gt 0 ]; do
    case "$1" in
        --version)
            if [ -r "$VERSION_FILE" ]; then
                printf 'praeco %s\n' "$(cat "$VERSION_FILE")"
                exit 0
            fi
            echo "[praeco] Error: version file $VERSION_FILE not found or not readable" >&2
            exit 1
            ;;
        --source)
            [ "$#" -ge 2 ] || { echo "[praeco] Error: --source requires a value" >&2; exit 1; }
            SOURCE="$2"
            shift 2
            ;;
        --source=*)
            SOURCE="${1#--source=}"
            shift
            ;;
        --)
            shift
            break
            ;;
        -*)
            echo "[praeco] Error: unknown option: $1" >&2
            exit 1
            ;;
        *)
            break
            ;;
    esac
done

if [ "$#" -lt 1 ] || [ -z "$1" ]; then
    echo "Usage: $0 [--source NAME] \"message\" [silent]" >&2
    exit 1
fi

MSG="$1"
SILENT="${2:-}"

CALLER_USER="$(id -un 2>/dev/null || whoami 2>/dev/null || echo unknown)"
MSG_HASH="$(printf '%s' "$MSG" | sha256sum | cut -c1-16)"
CTX="user=${CALLER_USER} source=${SOURCE:-none} hash=${MSG_HASH}"
echo "[praeco] hash: $MSG_HASH" >&2

if [ ! -r "$ENV_FILE" ]; then
    echo "[praeco] Error: env file $ENV_FILE not found or not readable" >&2
    log "ERROR env file $ENV_FILE not found or not readable ($CTX)"
    exit 1
fi

# shellcheck source=/dev/null
. "$ENV_FILE"

if [ -z "${PRAECO_TOKEN:-}" ] || [ -z "${PRAECO_CHAT_ID:-}" ]; then
    echo "[praeco] Error: PRAECO_TOKEN and PRAECO_CHAT_ID must be set in $ENV_FILE" >&2
    log "ERROR PRAECO_TOKEN or PRAECO_CHAT_ID missing in $ENV_FILE ($CTX)"
    exit 1
fi

if [ -n "$SOURCE" ]; then
    # Square brackets are Markdown link syntax; Telegram silently strips a
    # "[NAME]" prefix with no following "(url)". Bold text has no such clash.
    MSG="*${SOURCE}:* $MSG"
fi

RESPONSE_FILE="/tmp/praeco-response.$$"

HTTP_CODE=$(curl -s -X POST -o "$RESPONSE_FILE" -w '%{http_code}' \
    "https://api.telegram.org/bot${PRAECO_TOKEN}/sendMessage" \
    -d "chat_id=${PRAECO_CHAT_ID}" \
    -d "parse_mode=Markdown" \
    --data-urlencode "text=${MSG}") || {
    echo "[praeco] Error: curl failed to reach Telegram API" >&2
    log "ERROR curl failed to reach Telegram API ($CTX)"
    rm -f "$RESPONSE_FILE"
    exit 1
}

if [ "$HTTP_CODE" != "200" ]; then
    echo "[praeco] Error: Telegram API returned HTTP $HTTP_CODE" >&2
    cat "$RESPONSE_FILE" >&2
    echo >&2
    log "ERROR Telegram API returned HTTP $HTTP_CODE ($CTX)"
    rm -f "$RESPONSE_FILE"
    exit 1
fi

if [ "$SILENT" != "silent" ]; then
    cat "$RESPONSE_FILE"
    echo
fi

rm -f "$RESPONSE_FILE"
log "OK message sent ($CTX)"
